@page
@model YourNamespace.Pages.ReportsModel

<h2>Submit a Report</h2>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">
        @Model.SuccessMessage
    </div>
}

<!-- Display Reports in a Table -->
<h3>Existing Reports</h3>
<table class="table">
    <thead>
        <tr>
            <th>Report ID</th>
            <th>Citizen ID</th>
            <th>Report Type</th>
            <th>Details</th>
            <th>Submission Date</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var report in Model.Reports)
        {
            <tr>
                <td>@report.ReportID</td>
                <td>@report.CitizenID</td>
                <td>@report.ReportType</td>
                <td>@report.Details</td>
                <td>@report.SubmissionDate?.ToString("g")</td>
                <td>@report.Status</td>
                <td>
                    <!-- Delete Button -->
                    <form method="post" asp-page-handler="Delete" asp-route-reportId="@report.ReportID" onsubmit="return confirm('Are you sure you want to delete this report?');">
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Form to Submit a New Report -->
<h3>Submit a New Report</h3>
<form method="post">
    <div class="form-group">
        <label for="CitizenID">Citizen ID</label>
        <input type="number" class="form-control" id="CitizenID" name="CitizenID" asp-for="NewReport.CitizenID" required />
    </div>

    <div class="form-group">
        <label for="ReportType">Report Type</label>
        <input type="text" class="form-control" id="ReportType" name="ReportType" asp-for="NewReport.ReportType" required />
    </div>

    <div class="form-group">
        <label for="Details">Details</label>
        <textarea class="form-control" id="Details" name="Details" asp-for="NewReport.Details" required></textarea>
    </div>

    <div class="form-group">
        <label for="Status">Status</label>
        <input type="text" class="form-control" id="Status" name="Status" asp-for="NewReport.Status" readonly />
    </div>

    <button type="submit" class="btn btn-primary">Submit Report</button>
</form>

<!-- Form to Update Report Status -->
<h3>Update Report Status</h3>
<form method="post" asp-page-handler="UpdateStatus">
    <div class="form-group">
        <label for="ReportIDToUpdate">Report ID to Update</label>
        <input type="number" class="form-control" id="ReportIDToUpdate" name="ReportIDToUpdate" asp-for="ReportIDToUpdate" required />
    </div>

    <button type="submit" class="btn btn-warning">Mark as Completed</button>
</form>
