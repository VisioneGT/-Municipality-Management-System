@page
@model YourNamespace.Pages.StaffControllerModel
@{
    ViewData["Title"] = "Staff Management";
}

<h2>Staff Management</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<!-- Staff Data Table -->
@if (Model.StaffList != null && Model.StaffList.Any())
{
    <h3>Existing Staff Members</h3>
    <table class="table">
        <thead>
            <tr>
                <th>Staff ID</th> <!-- Added Staff ID column -->
                <th>Full Name</th>
                <th>Position</th>
                <th>Department</th>
                <th>Email</th>
                <th>Phone Number</th>
                <th>Hire Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var staff in Model.StaffList)
            {
                <tr>
                    <td>@staff.StaffID</td> <!-- Display Staff ID -->
                    <td>@staff.FullName</td>
                    <td>@staff.Position</td>
                    <td>@staff.Department</td>
                    <td>@staff.Email</td>
                    <td>@staff.PhoneNumber</td>
                    <td>@(staff.HireDate?.ToString("yyyy-MM-dd") ?? "N/A")</td>
                    <td>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@staff.StaffID" onsubmit="return confirm('Are you sure you want to delete this staff member?');">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No staff members available.</p>
}

<!-- Staff Creation Form -->
<h3>Add New Staff Member</h3>
<form method="post">
    <div class="form-group">
        <label for="FullName">Full Name</label>
        <input type="text" id="FullName" class="form-control" asp-for="Staff.FullName" />
        <span asp-validation-for="Staff.FullName" class="text-danger"></span>
    </div>
    
    <div class="form-group">
        <label for="Position">Position</label>
        <input type="text" id="Position" class="form-control" asp-for="Staff.Position" />
        <span asp-validation-for="Staff.Position" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="Department">Department</label>
        <input type="text" id="Department" class="form-control" asp-for="Staff.Department" />
        <span asp-validation-for="Staff.Department" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="Email">Email</label>
        <input type="email" id="Email" class="form-control" asp-for="Staff.Email" />
        <span asp-validation-for="Staff.Email" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="PhoneNumber">Phone Number</label>
        <input type="text" id="PhoneNumber" class="form-control" asp-for="Staff.PhoneNumber" />
        <span asp-validation-for="Staff.PhoneNumber" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="HireDate">Hire Date</label>
        <input type="date" id="HireDate" class="form-control" asp-for="Staff.HireDate" />
        <span asp-validation-for="Staff.HireDate" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create Staff</button>
</form>

<h3>Update Staff Information</h3>
<form method="post" asp-page-handler="Update">
    <div class="form-group">
        <label for="StaffID">Staff ID</label>
        <input type="number" id="StaffID" class="form-control" asp-for="Staff.StaffID" placeholder="Enter the Staff ID" required />
        <span asp-validation-for="Staff.StaffID" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="FullName">Full Name</label>
        <input type="text" id="FullName" class="form-control" asp-for="Staff.FullName" required />
        <span asp-validation-for="Staff.FullName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="Position">Position</label>
        <input type="text" id="Position" class="form-control" asp-for="Staff.Position" required />
        <span asp-validation-for="Staff.Position" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="Department">Department</label>
        <input type="text" id="Department" class="form-control" asp-for="Staff.Department" required />
        <span asp-validation-for="Staff.Department" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="PhoneNumber">Phone Number</label>
        <input type="text" id="PhoneNumber" class="form-control" asp-for="Staff.PhoneNumber" required />
        <span asp-validation-for="Staff.PhoneNumber" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="Email">Email</label>
        <input type="email" id="Email" class="form-control" asp-for="Staff.Email" required />
        <span asp-validation-for="Staff.Email" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Update Information</button>
</form>

